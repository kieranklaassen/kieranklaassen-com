# Dependencies
/node_modules
/vendor/bundle

# Logs, cache, and temp files
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
!/tmp/pids
/tmp/pids/*
!/tmp/pids/.keep

# Generated assets
/app/assets/builds/*
!/app/assets/builds/.keep
/public/assets
/public/vite*
/app/frontend/.vite

# Secrets and local environment
/config/master.key
/config/credentials/*.key
/.env*
/.kamal/deploy.env
/.kamal/secrets

# Local tooling
/.bundle
/.ruby-lsp
/.DS_Store
/output
/.bridgetown-cache
/.bridgetown-metadata
/.bridgetown-webpack
/.routes.json
